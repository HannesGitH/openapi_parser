{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "lldb",
            "request": "launch",
            "name": "Debug openapi_parser",
            "cargo": {
                "args": ["build"],
                "filter": {
                    "name": "openapi_parser",
                    "kind": "bin"
                }
            },
            "args": [
                "-u", "https://${input:base_url}/openapi-${env:SWAGGER_BASIC_SECR}",
                "-o", "out/lib/gen",
                "-d", "dart"
            ],
            "envFile": "${workspaceFolder}/.env",
            "cwd": "${workspaceFolder}"
        }
    ],
    "inputs": [
        {
            "id": "base_url",
            "description": "Base URL for the API",
            "default": "api.dev.blingcard.app",
            "type": "promptString"
        }
    ]
}
